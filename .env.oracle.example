# Copy to /etc/ice-monitor/env on the Oracle VM, then:
#   sudo chmod 600 /etc/ice-monitor/env
#   sudo chown root:root /etc/ice-monitor/env

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
DISCORD_BOT_TOKEN=your-discord-bot-token
ESI_CLIENT_ID=your-esi-client-id
ESI_CLIENT_SECRET=your-esi-client-secret
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown)
ICE_SYSTEM=Riavayed
ICE_INTERVAL=300
ICE_RESPAWN_HOURS=6
RESPAWN_ALERT_MINUTES_BEFORE=15
